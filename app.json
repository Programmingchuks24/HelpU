{
  "expo": {
    "name": "helpu",
    "slug": "helpu",
    "scheme":"helpu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png", 
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "backgroundColor": "#ffffff",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-font"
    ]
  }
}